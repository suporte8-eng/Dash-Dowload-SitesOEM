{
  "manifest_version": 3,
  "name": "AutoDownload Dash Extension",
  "version": "1.0.0",
  "description": "Automatiza e gerencia downloads de documentos técnicos direto no navegador.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoDownload Dash"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
